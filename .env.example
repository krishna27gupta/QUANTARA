# Quantara Environment Settings Example

# Common Environment
ENVIRONMENT=development
PROJECT_NAME="Quantara Platform"

# Backend FastAPI Settings
LOG_LEVEL=INFO

# PostgreSQL Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quantara

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend Next.js Settings
NEXT_PUBLIC_API_URL=http://localhost:8000
